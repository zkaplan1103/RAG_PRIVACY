# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Data — never commit raw corpora or computed indexes
data/raw/
data/processed/
data/index/

# Streamlit
.streamlit/secrets.toml

# Secrets — never commit API keys
.env
.env.*
*.env

# Terraform — never commit state or credentials
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl
infra/terraform.tfvars
infra/.build/

# Eval reports (generated; large; use artifacts instead)
eval/ragas/report_*.json

# Misc
.DS_Store
*.log

# Agent worktrees (transient; auto-cleaned)
.claude/worktrees/

# Personal setup runbooks (not for public consumption)
SETUP_BRIEF.txt
SETUP_TASKS.md
TESTING_CHECKLIST.md
